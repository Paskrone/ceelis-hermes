# Auf VPS nach /srv/hermes/.env kopieren (chmod 600), Werte ausfüllen.
# Werte werden von ./railway/init.sh in /opt/data/config.yaml injectiert (idempotent pro Boot).

# --- CEELIS-Portal MCP (required) ---
CEELIS_MCP_BEARER=
# CEELIS_MCP_URL=https://api.kundenportal.ceelis.com/functions/v1/mcp  # default, hier nicht setzen wenn unverändert

# --- Miro MCP (optional, nur wenn gesetzt wird mcp_servers.miro injectet) ---
MIRO_ACCESS_TOKEN=

# --- LLM-Provider ---
# Hinweis: KEIN ANTHROPIC_API_KEY hier. Claude Code wird via Subscription-Auth
# (OAuth Device-Code-Flow) im Container betrieben — nach erstem Container-Start einmalig:
#   docker exec -it hermes claude login
# Token persistiert in /opt/data (Volume), bleibt über Restarts.
# Atlas selbst nutzt LLM-Provider via OpenRouter (siehe railway/init.sh).
OPENROUTER_API_KEY=
GROQ_API_KEY=

# --- Model-Routing ---
HERMES_DEFAULT_MODEL=
HERMES_DELEGATION_MODEL=
HERMES_AUX_MODEL=google/gemini-2.5-flash
HERMES_AUX_COMPRESSION_MODEL=google/gemini-2.5-pro

# --- Dashboard (1=enabled, läuft auf :9119, von Caddy reverse-proxied) ---
HERMES_DASHBOARD=1

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=
TELEGRAM_HOME_CHANNEL_THREAD_ID=

# --- GitHub (für Atlas' git/gh Operationen) ---
GITHUB_TOKEN=

# --- Browserbase (optional, für web/browser-Skills) ---
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_PROXIES=false
BROWSERBASE_ADVANCED_STEALTH=false

# --- Diverse ---
TERMINAL_MODAL_IMAGE=
TERMINAL_TIMEOUT=
TERMINAL_LIFETIME_SECONDS=
BROWSER_SESSION_TIMEOUT=
BROWSER_INACTIVITY_TIMEOUT=
